# ─── DATABASE ────────────────────────────────────────────────────────────────
# Supabase (recommended) or your own Postgres on VPS
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
# For connection pooling (Supabase Transaction mode)
DATABASE_URL_UNPOOLED="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── AUTH (NextAuth v5) ───────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="https://gobig.cc"

# OAuth providers (optional — add as needed)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── EMAIL (Resend — free 3k/mo) ─────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@gobig.cc"
EMAIL_FROM_NAME="GoBig.cc"

# SMTP fallback (Mailgun / SendGrid / etc)
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT="587"
SMTP_USER="postmaster@gobig.cc"
SMTP_PASS="your-smtp-password"

# ─── PAYMENTS (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"

# ─── STORAGE (Supabase Storage / S3-compatible) ───────────────────────────────
STORAGE_BUCKET_DESIGNS="design-files"
STORAGE_BUCKET_AVATARS="avatars"
STORAGE_BUCKET_RESUMES="resumes"

# ─── ADMIN ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@gobig.cc"
# Admin password is set via seed script — stored as bcrypt hash in DB

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://gobig.cc"
NEXT_PUBLIC_APP_NAME="GoBig.cc"
NODE_ENV="production"
